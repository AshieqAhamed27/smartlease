# ─── DATABASE ──────────────────────────────────────────────
MONGO_URI="mongodb+srv://user:password@cluster.mongodb.net/smartlease?retryWrites=true&w=majority"

# ─── REDIS ─────────────────────────────────────────────────
# ENABLE_REDIS_QUEUE="false"
# REDIS_URL="redis://localhost:6379"

# ─── AUTH ──────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── ANTHROPIC (AI) ────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# Razorpay payments
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"
RAZORPAY_PRO_PLAN_ID="plan_your_pro_subscription_plan_id"
RAZORPAY_BUSINESS_PLAN_ID="plan_your_business_subscription_plan_id"
# Optional compatibility with InvoicePro env naming:
# RAZORPAY_MONTHLY_PLAN_ID can be used instead of RAZORPAY_PRO_PLAN_ID.
# RAZORPAY_YEARLY_PLAN_ID can be used instead of RAZORPAY_BUSINESS_PLAN_ID.
PAYMENT_SIMULATION="false"

# ─── FILE STORAGE (Cloudflare R2 / AWS S3) ─────────────────
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Optional alternative: Cloudflare R2 / AWS S3 instead of Cloudinary
# STORAGE_BUCKET="smartlease-uploads"
# STORAGE_REGION="auto"
# STORAGE_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
# STORAGE_ACCESS_KEY="your-access-key"
# STORAGE_SECRET_KEY="your-secret-key"
# STORAGE_PUBLIC_URL="https://your-cdn-url.com"

# ─── EMAIL (Resend) ─────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="SmartLease <hello@smartlease.in>"

# ─── APP ───────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
APP_URL="http://localhost:3000"
API_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:3000"

# ─── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── GOOGLE OAUTH (optional) ───────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
